project_id                 = null
parent_container_id        = "cmf-parent-container-id"
project_name               = "cmf-cloud-foundry"
project_owner_email        = null
region                     = "eu01"
enable_beta_resources      = true
service_account_key_path   = "/path/to/stackit-sa-key.json"

scf_org_name               = "cmf-spring-music-org"
cf_space_name              = "app"
admin_email                = ""
assign_roles               = false
cf_domain                  = "apps.01.cf.eu01.stackit.cloud"
cf_app_name                = "spring-music"
cf_app_host                = "spring-music-cmf"
spring_music_repo_url      = "https://github.com/cloudfoundry-samples/spring-music.git"

observability_plan_name            = "Observability-Starter-EU01"
postgres_name                      = "cmf-spring-music-postgres"
autoscaler_name                    = "cmf-spring-music-autoscaler"
deployment_environment             = "dev"
cf_postgres_service_offering_name  = "stackit-postgres-flex"
cf_postgres_service_plan_name      = "stackit-postgres-flex"
postgres_acl_items                 = ["193.148.160.0/19", "45.129.40.0/21"]
postgres_database_name             = "stackit"
postgres_bootstrap_key_name        = "tf-postgres-bootstrap"
cf_autoscaler_service_offering_name = "autoscaler"
cf_autoscaler_service_plan_name     = "autoscaler-free-plan"

# Recommended autoscaling thresholds (output metadata)
autoscaler_policy_min_instances                     = 1
autoscaler_policy_max_instances                     = 3
autoscaler_scale_up_throughput_threshold_rps        = 20
autoscaler_scale_up_throughput_breach_duration_secs = 60
autoscaler_scale_up_cpu_threshold_percent           = 45
autoscaler_scale_up_cpu_breach_duration_secs        = 60
autoscaler_scale_up_memory_threshold_mb             = 700
autoscaler_scale_up_memory_breach_duration_secs     = 120
autoscaler_scale_down_cpu_threshold_percent         = 20
autoscaler_scale_down_cpu_breach_duration_secs      = 120
autoscaler_scale_down_throughput_threshold_rps      = 3
autoscaler_scale_down_throughput_breach_duration_secs = 120
autoscaler_scale_up_cool_down_secs                  = 60
autoscaler_scale_down_cool_down_secs                = 120

# Optional load generator metadata for validation outputs
loadgen_enabled   = false
loadgen_mode      = "external-tool"
loadgen_app_name  = ""
loadgen_target_url = ""
loadgen_notes     = ""

# Observability scrape configs (required for meaningful app metrics in Grafana)
setup_observability_scrapeconfigs = true
spring_music_scrape_config_name   = "spring-music-metrics"
spring_music_metrics_path         = "/actuator/prometheus"
spring_music_scrape_interval      = "1m"
spring_music_scrape_timeout       = "10s"
spring_music_scrape_sample_limit  = 5000

# Optional loadgen scrape config (set URL host when loadgen app is deployed)
loadgen_scrape_config_name  = "spring-music-loadgen-metrics"
loadgen_metrics_path        = "/actuator/prometheus"
loadgen_scrape_interval     = "1m"
loadgen_scrape_timeout      = "10s"
loadgen_scrape_sample_limit = 5000

# Production recommendation:
# deployment_environment             = "prod"
# cf_postgres_service_plan_name      = "stackit-postgres-flex"

setup_project       = true
setup_observability = true
provision_observability_dashboard = false
setup_database      = true
bind_postgres_to_app = false
setup_postgres_db_with_stackit_provider = true
setup_cf_service_bindings = true
setup_autoscaler    = true
setup_autoscaler_policy = true
setup_workload      = true
setup_dns           = false
