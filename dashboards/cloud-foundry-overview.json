    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Flow: Loadgen Out vs App In",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": null,
      "targets": [
        {
          "refId": "A",
          "expr": "label_replace((sum(rate(http_client_requests_seconds_count{job=\"spring-music-loadgen-metrics\"}[1m])) or sum(rate(http_server_requests_seconds_count{job=\"spring-music-loadgen-metrics\",uri!~\"/actuator.*\"}[1m])) or vector(0)), \"series\", \"loadgen out req/s\", \"\", \"\")",
          "legendFormat": "{{series}}"
        },
        {
          "refId": "B",
          "expr": "label_replace((sum(rate(http_server_requests_seconds_count{job=\"spring-music-metrics\",uri!~\"/actuator.*\"}[1m])) or vector(0)), \"series\", \"app in req/s\", \"\", \"\")",
          "legendFormat": "{{series}}"
        },
        {
          "refId": "C",
          "expr": "label_replace(clamp_min((sum(rate(http_client_requests_seconds_count{job=\"spring-music-loadgen-metrics\"}[1m])) or sum(rate(http_server_requests_seconds_count{job=\"spring-music-loadgen-metrics\",uri!~\"/actuator.*\"}[1m])) or vector(0)) - (sum(rate(http_server_requests_seconds_count{job=\"spring-music-metrics\",uri!~\"/actuator.*\"}[1m])) or vector(0)), 0), \"series\", \"gap req/s\", \"\", \"\")",
